# Telepath environment variables
# Copy to .env for local development only. Never commit .env.

# Required for MVP. Server-side only in /api/ai.ts.
ANTHROPIC_API_KEY=

# Required in production for distributed edge rate limiting.
# Create a free Upstash Redis database at https://upstash.com and copy REST credentials.
# Local/test fallback: if unset, rate limiting is disabled outside production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required in production for /api/ai.ts browser access control.
# Comma-separated exact origins allowed to call the edge proxy from browsers.
# Include only the deployed app origins you intend to trust.
ALLOWED_ORIGINS=

# Comma-separated Anthropic models allowed by the edge proxy.
# ALLOWED_ANTHROPIC_MODELS=claude-sonnet-4-5-20250929,claude-haiku-4-5-20251001
